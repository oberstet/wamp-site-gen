# wamp-site-gen is a publishing repo (no Python package of its own). The only
# things to ignore are local artifacts produced when running the publish flow
# (.github/workflows/publish-site.yaml) by hand, plus the usual editor/OS cruft.

# Local build artifacts from the publish workflow
/dist/
/wamp-proto/

# Python venv created by `.ai`/`just` tooling
.venv/
__pycache__/
*.py[cod]

# Editor / OS cruft
*~
*.swp
.DS_Store
.idea/
.vscode/
